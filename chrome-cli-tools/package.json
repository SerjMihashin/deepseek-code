{
  "name": "chrome-cli-tools",
  "version": "3.0.0",
  "description": "Набор CLI утилит для управления Google Chrome через Puppeteer. Автоматизация браузера, парсинг сайтов, прохождение тестов, DevTools функции.",
  "main": "chrome-lib.js",
  "bin": {
    "chrome": "./chrome-cli.js",
    "chrome-open": "./chrome-open.js",
    "chrome-tab": "./chrome-tab.js",
    "chrome-click": "./chrome-click.js",
    "chrome-fill": "./chrome-fill.js",
    "chrome-scroll": "./chrome-scroll.js",
    "chrome-wait": "./chrome-wait.js",
    "chrome-text": "./chrome-text.js",
    "chrome-html": "./chrome-html.js",
    "chrome-eval": "./chrome-eval.js",
    "chrome-console": "./chrome-console.js",
    "chrome-network": "./chrome-network.js",
    "chrome-storage": "./chrome-storage.js",
    "chrome-cookies": "./chrome-cookies.js",
    "chrome-shot": "./chrome-shot.js",
    "chrome-quiz": "./chrome-quiz.js",
    "chrome-nav": "./chrome-nav.js",
    "chrome-browser-start": "./chrome-browser-start.js"
  },
  "scripts": {
    "test": "node chrome-eval.js https://example.com \"document.title\"",
    "start": "node chrome-open.js https://example.com",
    "chrome": "node chrome-cli.js"
  },
  "keywords": [
    "chrome",
    "puppeteer",
    "browser-automation",
    "web-scraping",
    "cli-tools",
    "devtools",
    "testing",
    "automation"
  ],
  "author": {
    "name": "Serj Mikhashin",
    "email": "serjmihashin1989@gmail.com",
    "url": "https://github.com/SerjMihashin"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SerjMihashin/chrome-cli-tools.git"
  },
  "bugs": {
    "url": "https://github.com/SerjMihashin/chrome-cli-tools/issues"
  },
  "homepage": "https://github.com/SerjMihashin/chrome-cli-tools#readme",
  "dependencies": {
    "puppeteer-core": "^24.39.1"
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32"
  ]
}
